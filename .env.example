# DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE_NAME
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DATABASE_NAME

# SERVER
PORT=3000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=change_me_access_minimum_32_characters
JWT_REFRESH_SECRET=change_me_refresh_minimum_32_characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=30


# EMAIL (Gmail)
# Bật "App Password" tại: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password


# GOOGLE OAUTH
# Tạo tại: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# CORS / URL
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# STRIPE (optional)
# Lấy tại: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# VNPAY
# Đăng ký sandbox tại: https://sandbox.vnpayment.vn/devreg
VNPAY_TMNCODE=your_tmn_code
VNPAY_HASHSECRET=your_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Dùng ngrok để expose localhost khi test VNPay IPN
# Cài ngrok: https://ngrok.com → chạy: ngrok http 3000
VNPAY_TUNNEL_HOST=https://your-ngrok-url.ngrok-free.app
VNPAY_RETURN_URL=${VNPAY_TUNNEL_HOST}/payment/vnpay-return
VNPAY_IPN_URL=${VNPAY_TUNNEL_HOST}/payment/vnpay-ipn

# ========================
# SMTP (dùng lại Gmail ở trên)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=${EMAIL_USER}
SMTP_PASSWORD=${EMAIL_PASS}
EMAIL_FROM=YourAppName <your_gmail@gmail.com>